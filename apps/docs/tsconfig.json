{
  "compilerOptions": {
    "target": "ES2023",
    "types": ["node", "react", "react-dom"],
    "lib": ["dom", "dom.iterable", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    /* next-start: Next.js auto adds if not present */
    "allowJs": false,
    "incremental": false,
    "resolveJsonModule": true,
    /* next-end: Next.js auto adds if not present */
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@icons": ["./src/components/assets/icons.tsx"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "./src",
    "./scripts",
    "./shilp.config.ts",
    "./next.config.ts",
    "./oxfmt.config.ts",
    "./oxlint.config.ts",
    "./next-env.d.ts",
    "dist/types/**/*.ts",
    "dist/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["./node_modules"]
}
