{
	"$schema": "https://v2-9-14.turborepo.dev/schema.json",
	"dangerouslyDisablePackageManagerCheck": true,
	"tasks": {
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"check": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"lint-staged": {
			"cache": false
		},
		"fix": {
			"cache": false
		},
		"build": {
			"dependsOn": ["check"],
			"outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
		},
		"publish-it": {
			"dependsOn": ["build"],
			"cache": false
		}
	}
}
